# 千问 API 配置（阿里云 DashScope）
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 自定义 Qwen API Endpoint
QWEN_API_ENDPOINT=sfm_llminference_dp_cn-ykh4qz9y80001

# Qdrant 配置（本地测试使用内存模式）
QDRANT_MODE=memory
# 如果使用独立服务：
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
QDRANT_COLLECTION=campus_ai_kb

# MySQL 数据库配置
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/campus_ai?charset=utf8mb4
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=campus_ai

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 服务配置
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# 提醒系统配置
REMINDER_CHECK_INTERVAL=60  # 检查间隔（秒）
REMINDER_DEFAULT_TIMES=1d,3h,1h  # 默认提前提醒时间

# JWT 配置
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 管理员默认账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123